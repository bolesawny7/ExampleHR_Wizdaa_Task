# Time-Off Microservice — Environment Variables

# HTTP
PORT=3000
NODE_ENV=development

# JWT
# Shared HMAC secret for simplicity in this exercise; in production use RS256 + JWKS.
JWT_SECRET=change_me_in_production_use_strong_random_value_of_sufficient_length

# SQLite
# Use ':memory:' for ephemeral DB (tests default to this).
DATABASE_PATH=./data/time-off.sqlite

# HCM integration
HCM_BASE_URL=http://localhost:4000
HCM_WEBHOOK_SECRET=change_me_hcm_webhook_hmac_secret
HCM_API_KEY=change_me_hcm_outbound_api_key

# Outbox worker
OUTBOX_INTERVAL_MS=2000
OUTBOX_BATCH_SIZE=20
OUTBOX_MAX_ATTEMPTS=8
