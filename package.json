{
  "name": "time-off-service",
  "version": "1.0.0",
  "private": true,
  "description": "Time-Off Microservice (NestJS + SQLite, JavaScript).",
  "license": "UNLICENSED",
  "scripts": {
    "build": "babel src -d dist --copy-files",
    "start": "node -r @babel/register src/main.js",
    "start:dev": "nodemon --watch src --exec \"node -r @babel/register src/main.js\"",
    "start:prod": "node dist/main.js",
    "mock:hcm": "node -r @babel/register test/mocks/hcm-mock-server.js",
    "test": "jest --runInBand",
    "test:unit": "jest --runInBand --testPathPattern=test/unit",
    "test:integration": "jest --runInBand --testPathPattern=test/integration",
    "test:e2e": "jest --runInBand --testPathPattern=test/e2e",
    "test:cov": "jest --runInBand --coverage",
    "lint": "eslint \"src/**/*.js\" \"test/**/*.js\"",
    "format": "prettier --write \"src/**/*.js\" \"test/**/*.js\""
  },
  "dependencies": {
    "@nestjs/common": "^10.3.10",
    "@nestjs/core": "^10.3.10",
    "@nestjs/platform-express": "^10.3.10",
    "@nestjs/schedule": "^4.1.0",
    "better-sqlite3": "^11.1.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^3.3.7",
    "pino": "^9.3.2",
    "pino-http": "^10.2.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@babel/cli": "^7.24.8",
    "@babel/core": "^7.24.9",
    "@babel/plugin-proposal-decorators": "^7.24.7",
    "@babel/plugin-transform-class-properties": "^7.24.7",
    "@babel/preset-env": "^7.24.8",
    "@babel/register": "^7.24.6",
    "@nestjs/testing": "^10.4.22",
    "babel-jest": "^29.7.0",
    "babel-plugin-parameter-decorator": "^1.0.16",
    "babel-plugin-transform-typescript-metadata": "^0.4.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "<rootDir>/test/**/*.spec.js",
      "<rootDir>/test/**/*.e2e-spec.js"
    ],
    "transform": {
      "^.+\\.js$": "babel-jest"
    },
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/main.js"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "text-summary",
      "html",
      "lcov"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 75,
        "functions": 85,
        "lines": 85,
        "statements": 85
      }
    }
  }
}
